# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# ignore notes-during-refactoring folder
notes-during-refactoring/

# Bulk run demo outputs
/demo-runs/

# Environment files
.env

# OS files
.DS_Store
.copilot/config.json
.copilot/logs/*

# Sync skill (root-only, not synced to downstream fork)
.claude/skills/sync-downstream/
# eval workspace
.claude/skills/tf-research-policy-aws-workspace

# Python bytecode
__pycache__/
*.pyc
reference/terraform_1.15.0-policy20261002_darwin_amd64.zip
reference/terraform_1.15.0-policy20261002_darwin_arm64 (1).zip
.claude/skills/tf-policy-evaluations-workspace/
.claude/skills/tf-research-policy-azure-workspace/

# Temp script
_run.sh